# CloudForge — environment variables
# Copy to .env and fill in real values. .env is gitignored.
#
# This file documents vars used by:
#   - Local Docker Compose (docker-compose.yaml)
#   - Railway (backend + celery services)
#   - Vercel (frontend only — needs VITE_* vars)

# ---------------------------------------------------------------------------
# Backend (FastAPI) — Required for local dev and Railway
# ---------------------------------------------------------------------------

# Database — Railway auto-injects DATABASE_URL when you add the Postgres plugin
DATABASE_URL=postgresql://cloudforge:cloudforge_dev_password@postgres:5432/cloudforge

# Redis — Railway auto-injects REDIS_URL when you add the Redis plugin
REDIS_URL=redis://redis:6379/0

# JWT signing key. In production, generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=dev_secret_key_change_in_production

# development | production
ENVIRONMENT=development

# Default admin user created on first boot. CHANGE THESE before exposing
# CloudForge beyond localhost — anyone hitting the instance knows the defaults.
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=admin123
INITIAL_ADMIN_EMAIL=admin@cloudforge.dev

# Comma-separated list. In production include your Vercel URL.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ---------------------------------------------------------------------------
# Feature keys — optional but needed for full functionality
# ---------------------------------------------------------------------------

# Infracost (cost estimation). Get from https://www.infracost.io/
INFRACOST_API_KEY=

# Claude AI assistant. Optional. Leave blank to disable /api/assistant endpoint.
ANTHROPIC_API_KEY=

# Google OAuth for social login. Optional.
GOOGLE_OAUTH_CLIENT_ID=

# LocalStack Pro (local AWS emulation — NOT needed in production)
LOCALSTACK_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# Frontend (Vite) — set these in Vercel project settings, not here
# ---------------------------------------------------------------------------

# Public backend URL. In production: https://<your-service>.up.railway.app
VITE_API_URL=http://localhost:8000

# WebSocket URL for real-time collaboration. Same host as VITE_API_URL, ws:// → wss:// in prod
VITE_WS_URL=ws://localhost:8000

# Dev-only: internal proxy target inside Docker network
VITE_BACKEND_URL=http://backend:8000
