# CloudForge Production Environment Variables
# Copy this file to .env and fill in the values

# =====================
# Application Settings
# =====================
ENVIRONMENT=production
VERSION=1.0.0
BUILD_DATE=2024-01-01

# =====================
# PostgreSQL Database
# =====================
POSTGRES_USER=cloudforge
POSTGRES_PASSWORD=change_this_password_in_production
POSTGRES_DB=cloudforge
POSTGRES_PORT=5432
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=0

# =====================
# Redis Cache
# =====================
REDIS_PASSWORD=redis_password_change_me
REDIS_PORT=6379

# =====================
# Security & JWT
# =====================
# IMPORTANT: Generate secure random keys for production!
# You can use: openssl rand -hex 32
SECRET_KEY=generate_a_secure_random_key_here
JWT_SECRET_KEY=generate_a_different_secure_key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =====================
# Backend Settings
# =====================
BACKEND_PORT=8000
DEBUG=false
LOG_LEVEL=info
GEMINI_API_KEY=AIzaSyCzgObFPPI7fvAQ-Jw7BYe8u-HAlD_rSNA

# CORS Origins (comma-separated list)
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# =====================
# Frontend Settings
# =====================
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:8000
VITE_PIPELINE_API_URL=http://localhost:8001

# =====================
# Terraform Settings
# =====================
TERRAFORM_VERSION=1.6.0

# =====================
# Cloud Provider Defaults
# =====================
AWS_DEFAULT_REGION=us-east-1
AZURE_DEFAULT_LOCATION=eastus
GCP_DEFAULT_REGION=us-central1

# =====================
# Email Settings (Optional)
# =====================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@cloudforge.com

# =====================
# Monitoring (Optional)
# =====================
SENTRY_DSN=
ENABLE_METRICS=true

# =====================
# Nginx Reverse Proxy
# =====================
HTTP_PORT=80
HTTPS_PORT=443

# =====================
# Prometheus (Optional)
# =====================
PROMETHEUS_PORT=9090

# =====================
# Grafana (Optional)
# =====================
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
GRAFANA_ROOT_URL=http://localhost:3001

# =====================
# Backup Settings (Optional)
# =====================
BACKUP_KEEP_DAYS=7

# =====================
# SSL/TLS Settings (Optional)
# =====================
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem
# SSL_CA_PATH=/path/to/ca.pem

# =====================
# Docker Resource Limits
# =====================
# These are set in docker-compose.prod.yml
# Uncomment and adjust if needed:
# BACKEND_MEMORY_LIMIT=2G
# BACKEND_CPU_LIMIT=2
# POSTGRES_MEMORY_LIMIT=1G
# REDIS_MEMORY_LIMIT=256M

# =====================
# Production Checklist
# =====================
# [ ] Change all default passwords
# [ ] Generate secure SECRET_KEY and JWT_SECRET_KEY
# [ ] Set correct CORS_ORIGINS
# [ ] Configure SMTP for email (if needed)
# [ ] Set up SSL certificates (if using HTTPS)
# [ ] Review resource limits
# [ ] Configure backup retention
# [ ] Set up monitoring (Sentry, Prometheus, Grafana)
# [ ] Test database connections
# [ ] Test Redis connections
# [ ] Verify Terraform installation
# [ ] Test health check endpoints
