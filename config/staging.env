# CloudForge Staging Environment Configuration
# DO NOT commit with actual values - use secrets management

# Environment
ENVIRONMENT=staging
DEBUG=false

# Database
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:5432/cloudforge_staging
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://${REDIS_HOST}:6379/0

# Authentication
SECRET_KEY=${JWT_SECRET_KEY}
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# CORS
CORS_ORIGINS=https://staging.cloudforge.example.com

# Celery
CELERY_BROKER_URL=redis://${REDIS_HOST}:6379/1
CELERY_RESULT_BACKEND=redis://${REDIS_HOST}:6379/2

# Cloud Providers
AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}
AWS_DEFAULT_REGION=us-east-1

# Azure
AZURE_SUBSCRIPTION_ID=${AZURE_SUBSCRIPTION_ID}
AZURE_TENANT_ID=${AZURE_TENANT_ID}
AZURE_CLIENT_ID=${AZURE_CLIENT_ID}
AZURE_CLIENT_SECRET=${AZURE_CLIENT_SECRET}

# GCP
GOOGLE_APPLICATION_CREDENTIALS=/etc/cloudforge/gcp-credentials.json

# External Services
INFRACOST_API_KEY=${INFRACOST_API_KEY}
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Feature Flags
FEATURE_AI_ASSISTANT=true
FEATURE_TERRAFORM_V2=true

# Performance
WORKERS=4
WORKER_CONNECTIONS=1000
