# CloudForge Development Environment Configuration
# Copy this file to .env and fill in the values

# Environment
ENVIRONMENT=development
DEBUG=true

# Database
DATABASE_URL=postgresql://cloudforge:cloudforge@localhost:5432/cloudforge
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0

# Authentication
SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Cloud Providers (optional in development)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# Azure (optional in development)
# AZURE_SUBSCRIPTION_ID=
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# GCP (optional in development)
# GOOGLE_APPLICATION_CREDENTIALS=

# External Services (optional in development)
# INFRACOST_API_KEY=
# ANTHROPIC_API_KEY=

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=text

# Feature Flags
FEATURE_AI_ASSISTANT=true
FEATURE_TERRAFORM_V2=true
