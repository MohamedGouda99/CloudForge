{
  "category": "containers",
  "categoryName": "Containers",
  "services": [
    {
      "id": "container_cluster",
      "name": "GKE Cluster",
      "description": "Google Kubernetes Engine cluster",
      "terraform_resource": "google_container_cluster",
      "icon": "box",
      "inputs": {
        "required": [
          { "name": "name", "type": "string", "description": "Cluster name" },
          { "name": "location", "type": "string", "description": "Zone or region" }
        ],
        "optional": [
          { "name": "project", "type": "string", "description": "Project ID" },
          { "name": "description", "type": "string", "description": "Description" },
          { "name": "initial_node_count", "type": "number", "description": "Initial node count" },
          { "name": "remove_default_node_pool", "type": "bool", "description": "Remove default pool" },
          { "name": "network", "type": "string", "description": "VPC network" },
          { "name": "subnetwork", "type": "string", "description": "Subnetwork" },
          { "name": "cluster_ipv4_cidr", "type": "string", "description": "Cluster IPv4 CIDR" },
          { "name": "min_master_version", "type": "string", "description": "Min master version" },
          { "name": "node_version", "type": "string", "description": "Node version" },
          { "name": "deletion_protection", "type": "bool", "description": "Deletion protection", "default": true },
          { "name": "enable_autopilot", "type": "bool", "description": "Enable Autopilot" },
          { "name": "enable_shielded_nodes", "type": "bool", "description": "Shielded nodes", "default": true },
          { "name": "enable_intranode_visibility", "type": "bool", "description": "Intranode visibility" },
          { "name": "enable_l4_ilb_subsetting", "type": "bool", "description": "L4 ILB subsetting" },
          { "name": "enable_legacy_abac", "type": "bool", "description": "Legacy ABAC", "default": false },
          { "name": "enable_tpu", "type": "bool", "description": "Enable TPU" },
          { "name": "default_max_pods_per_node", "type": "number", "description": "Max pods per node" },
          { "name": "logging_service", "type": "string", "description": "Logging service" },
          { "name": "monitoring_service", "type": "string", "description": "Monitoring service" },
          { "name": "networking_mode", "type": "string", "description": "Networking mode", "options": ["VPC_NATIVE", "ROUTES"] },
          { "name": "datapath_provider", "type": "string", "description": "Datapath provider", "options": ["DATAPATH_PROVIDER_UNSPECIFIED", "LEGACY_DATAPATH", "ADVANCED_DATAPATH"] },
          { "name": "resource_labels", "type": "map", "description": "Resource labels" }
        ],
        "blocks": [
          {
            "name": "node_config",
            "required": false,
            "attributes": [
              { "name": "machine_type", "type": "string" },
              { "name": "disk_size_gb", "type": "number" },
              { "name": "disk_type", "type": "string", "options": ["pd-standard", "pd-balanced", "pd-ssd"] },
              { "name": "image_type", "type": "string" },
              { "name": "labels", "type": "map" },
              { "name": "local_ssd_count", "type": "number" },
              { "name": "metadata", "type": "map" },
              { "name": "min_cpu_platform", "type": "string" },
              { "name": "oauth_scopes", "type": "list" },
              { "name": "preemptible", "type": "bool" },
              { "name": "spot", "type": "bool" },
              { "name": "service_account", "type": "string" },
              { "name": "tags", "type": "list" },
              { "name": "boot_disk_kms_key", "type": "string" },
              { "name": "node_group", "type": "string" }
            ],
            "blocks": [
              {
                "name": "shielded_instance_config",
                "attributes": [
                  { "name": "enable_secure_boot", "type": "bool" },
                  { "name": "enable_integrity_monitoring", "type": "bool" }
                ]
              },
              {
                "name": "workload_metadata_config",
                "attributes": [
                  { "name": "mode", "type": "string", "options": ["MODE_UNSPECIFIED", "GCE_METADATA", "GKE_METADATA"] }
                ]
              },
              {
                "name": "kubelet_config",
                "attributes": [
                  { "name": "cpu_manager_policy", "type": "string" },
                  { "name": "cpu_cfs_quota", "type": "bool" },
                  { "name": "cpu_cfs_quota_period", "type": "string" },
                  { "name": "pod_pids_limit", "type": "number" }
                ]
              },
              {
                "name": "linux_node_config",
                "attributes": [
                  { "name": "sysctls", "type": "map" }
                ]
              },
              {
                "name": "gcfs_config",
                "attributes": [
                  { "name": "enabled", "type": "bool", "required": true }
                ]
              },
              {
                "name": "gvnic",
                "attributes": [
                  { "name": "enabled", "type": "bool", "required": true }
                ]
              },
              {
                "name": "taint",
                "multiple": true,
                "attributes": [
                  { "name": "key", "type": "string", "required": true },
                  { "name": "value", "type": "string", "required": true },
                  { "name": "effect", "type": "string", "required": true, "options": ["NO_SCHEDULE", "PREFER_NO_SCHEDULE", "NO_EXECUTE"] }
                ]
              },
              {
                "name": "guest_accelerator",
                "multiple": true,
                "attributes": [
                  { "name": "type", "type": "string", "required": true },
                  { "name": "count", "type": "number", "required": true },
                  { "name": "gpu_partition_size", "type": "string" },
                  { "name": "gpu_sharing_config", "type": "list" },
                  { "name": "gpu_driver_installation_config", "type": "list" }
                ]
              },
              {
                "name": "reservation_affinity",
                "attributes": [
                  { "name": "consume_reservation_type", "type": "string", "required": true },
                  { "name": "key", "type": "string" },
                  { "name": "values", "type": "list" }
                ]
              }
            ]
          },
          {
            "name": "ip_allocation_policy",
            "required": false,
            "attributes": [
              { "name": "cluster_secondary_range_name", "type": "string" },
              { "name": "services_secondary_range_name", "type": "string" },
              { "name": "cluster_ipv4_cidr_block", "type": "string" },
              { "name": "services_ipv4_cidr_block", "type": "string" },
              { "name": "stack_type", "type": "string", "options": ["IPV4", "IPV4_IPV6"] }
            ],
            "blocks": [
              {
                "name": "pod_cidr_overprovision_config",
                "attributes": [
                  { "name": "disabled", "type": "bool", "required": true }
                ]
              }
            ]
          },
          {
            "name": "master_auth",
            "required": false,
            "blocks": [
              {
                "name": "client_certificate_config",
                "required": true,
                "attributes": [
                  { "name": "issue_client_certificate", "type": "bool", "required": true }
                ]
              }
            ]
          },
          {
            "name": "master_authorized_networks_config",
            "required": false,
            "attributes": [
              { "name": "gcp_public_cidrs_access_enabled", "type": "bool" }
            ],
            "blocks": [
              {
                "name": "cidr_blocks",
                "multiple": true,
                "attributes": [
                  { "name": "cidr_block", "type": "string", "required": true },
                  { "name": "display_name", "type": "string" }
                ]
              }
            ]
          },
          {
            "name": "private_cluster_config",
            "required": false,
            "attributes": [
              { "name": "enable_private_nodes", "type": "bool" },
              { "name": "enable_private_endpoint", "type": "bool" },
              { "name": "master_ipv4_cidr_block", "type": "string" },
              { "name": "private_endpoint_subnetwork", "type": "string" }
            ],
            "blocks": [
              {
                "name": "master_global_access_config",
                "attributes": [
                  { "name": "enabled", "type": "bool", "required": true }
                ]
              }
            ]
          },
          {
            "name": "workload_identity_config",
            "required": false,
            "attributes": [
              { "name": "workload_pool", "type": "string" }
            ]
          },
          {
            "name": "addons_config",
            "required": false,
            "blocks": [
              {
                "name": "http_load_balancing",
                "attributes": [
                  { "name": "disabled", "type": "bool" }
                ]
              },
              {
                "name": "horizontal_pod_autoscaling",
                "attributes": [
                  { "name": "disabled", "type": "bool" }
                ]
              },
              {
                "name": "network_policy_config",
                "attributes": [
                  { "name": "disabled", "type": "bool" }
                ]
              },
              {
                "name": "gcp_filestore_csi_driver_config",
                "attributes": [
                  { "name": "enabled", "type": "bool" }
                ]
              },
              {
                "name": "gcs_fuse_csi_driver_config",
                "attributes": [
                  { "name": "enabled", "type": "bool" }
                ]
              },
              {
                "name": "dns_cache_config",
                "attributes": [
                  { "name": "enabled", "type": "bool" }
                ]
              },
              {
                "name": "gce_persistent_disk_csi_driver_config",
                "attributes": [
                  { "name": "enabled", "type": "bool" }
                ]
              },
              {
                "name": "gke_backup_agent_config",
                "attributes": [
                  { "name": "enabled", "type": "bool" }
                ]
              },
              {
                "name": "config_connector_config",
                "attributes": [
                  { "name": "enabled", "type": "bool" }
                ]
              }
            ]
          },
          {
            "name": "cluster_autoscaling",
            "required": false,
            "attributes": [
              { "name": "enabled", "type": "bool" },
              { "name": "autoscaling_profile", "type": "string", "options": ["BALANCED", "OPTIMIZE_UTILIZATION"] }
            ],
            "blocks": [
              {
                "name": "resource_limits",
                "multiple": true,
                "attributes": [
                  { "name": "resource_type", "type": "string", "required": true },
                  { "name": "minimum", "type": "number" },
                  { "name": "maximum", "type": "number" }
                ]
              },
              {
                "name": "auto_provisioning_defaults",
                "attributes": [
                  { "name": "oauth_scopes", "type": "list" },
                  { "name": "service_account", "type": "string" },
                  { "name": "disk_size", "type": "number" },
                  { "name": "disk_type", "type": "string" },
                  { "name": "image_type", "type": "string" },
                  { "name": "min_cpu_platform", "type": "string" },
                  { "name": "boot_disk_kms_key", "type": "string" }
                ],
                "blocks": [
                  {
                    "name": "management",
                    "attributes": [
                      { "name": "auto_upgrade", "type": "bool" },
                      { "name": "auto_repair", "type": "bool" }
                    ]
                  },
                  {
                    "name": "upgrade_settings",
                    "attributes": [
                      { "name": "strategy", "type": "string", "options": ["SURGE", "BLUE_GREEN"] },
                      { "name": "max_surge", "type": "number" },
                      { "name": "max_unavailable", "type": "number" }
                    ],
                    "blocks": [
                      {
                        "name": "blue_green_settings",
                        "attributes": [
                          { "name": "node_pool_soak_duration", "type": "string" }
                        ],
                        "blocks": [
                          {
                            "name": "standard_rollout_policy",
                            "attributes": [
                              { "name": "batch_percentage", "type": "number" },
                              { "name": "batch_node_count", "type": "number" },
                              { "name": "batch_soak_duration", "type": "string" }
                            ]
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "name": "shielded_instance_config",
                    "attributes": [
                      { "name": "enable_secure_boot", "type": "bool" },
                      { "name": "enable_integrity_monitoring", "type": "bool" }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "name": "network_policy",
            "required": false,
            "attributes": [
              { "name": "enabled", "type": "bool", "required": true },
              { "name": "provider", "type": "string", "options": ["CALICO", "PROVIDER_UNSPECIFIED"] }
            ]
          },
          {
            "name": "logging_config",
            "required": false,
            "attributes": [
              { "name": "enable_components", "type": "list", "required": true }
            ]
          },
          {
            "name": "monitoring_config",
            "required": false,
            "attributes": [
              { "name": "enable_components", "type": "list" }
            ],
            "blocks": [
              {
                "name": "managed_prometheus",
                "attributes": [
                  { "name": "enabled", "type": "bool", "required": true }
                ]
              },
              {
                "name": "advanced_datapath_observability_config",
                "attributes": [
                  { "name": "enable_metrics", "type": "bool" },
                  { "name": "relay_mode", "type": "string" }
                ]
              }
            ]
          },
          {
            "name": "maintenance_policy",
            "required": false,
            "blocks": [
              {
                "name": "recurring_window",
                "attributes": [
                  { "name": "start_time", "type": "string", "required": true },
                  { "name": "end_time", "type": "string", "required": true },
                  { "name": "recurrence", "type": "string", "required": true }
                ]
              },
              {
                "name": "daily_maintenance_window",
                "attributes": [
                  { "name": "start_time", "type": "string", "required": true }
                ]
              },
              {
                "name": "maintenance_exclusion",
                "multiple": true,
                "attributes": [
                  { "name": "exclusion_name", "type": "string", "required": true },
                  { "name": "start_time", "type": "string", "required": true },
                  { "name": "end_time", "type": "string", "required": true }
                ],
                "blocks": [
                  {
                    "name": "exclusion_options",
                    "attributes": [
                      { "name": "scope", "type": "string", "required": true, "options": ["NO_UPGRADES", "NO_MINOR_UPGRADES", "NO_MINOR_OR_NODE_UPGRADES"] }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "name": "release_channel",
            "required": false,
            "attributes": [
              { "name": "channel", "type": "string", "required": true, "options": ["UNSPECIFIED", "RAPID", "REGULAR", "STABLE"] }
            ]
          },
          {
            "name": "binary_authorization",
            "required": false,
            "attributes": [
              { "name": "evaluation_mode", "type": "string", "options": ["DISABLED", "PROJECT_SINGLETON_POLICY_ENFORCE"] }
            ]
          },
          {
            "name": "gateway_api_config",
            "required": false,
            "attributes": [
              { "name": "channel", "type": "string", "required": true, "options": ["CHANNEL_DISABLED", "CHANNEL_EXPERIMENTAL", "CHANNEL_STANDARD"] }
            ]
          },
          {
            "name": "dns_config",
            "required": false,
            "attributes": [
              { "name": "cluster_dns", "type": "string", "options": ["PLATFORM_DEFAULT", "CLOUD_DNS", "KUBE_DNS"] },
              { "name": "cluster_dns_scope", "type": "string", "options": ["DNS_SCOPE_UNSPECIFIED", "CLUSTER_SCOPE", "VPC_SCOPE"] },
              { "name": "cluster_dns_domain", "type": "string" }
            ]
          },
          {
            "name": "vertical_pod_autoscaling",
            "required": false,
            "attributes": [
              { "name": "enabled", "type": "bool", "required": true }
            ]
          },
          {
            "name": "node_pool_defaults",
            "required": false,
            "blocks": [
              {
                "name": "node_config_defaults",
                "blocks": [
                  {
                    "name": "gcfs_config",
                    "attributes": [
                      { "name": "enabled", "type": "bool", "required": true }
                    ]
                  },
                  {
                    "name": "logging_variant",
                    "attributes": [
                      { "name": "variant", "type": "string", "required": true, "options": ["DEFAULT", "MAX_THROUGHPUT"] }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "name": "service_external_ips_config",
            "required": false,
            "attributes": [
              { "name": "enabled", "type": "bool", "required": true }
            ]
          },
          {
            "name": "security_posture_config",
            "required": false,
            "attributes": [
              { "name": "mode", "type": "string", "options": ["DISABLED", "BASIC", "ENTERPRISE"] },
              { "name": "vulnerability_mode", "type": "string", "options": ["VULNERABILITY_DISABLED", "VULNERABILITY_BASIC", "VULNERABILITY_ENTERPRISE"] }
            ]
          },
          {
            "name": "fleet",
            "required": false,
            "attributes": [
              { "name": "project", "type": "string" }
            ]
          },
          {
            "name": "cost_management_config",
            "required": false,
            "attributes": [
              { "name": "enabled", "type": "bool", "required": true }
            ]
          }
        ]
      },
      "outputs": [
        { "name": "id", "type": "string", "description": "Cluster ID" },
        { "name": "self_link", "type": "string", "description": "Self link" },
        { "name": "endpoint", "type": "string", "description": "Cluster endpoint" },
        { "name": "cluster_ca_certificate", "type": "string", "description": "CA certificate", "sensitive": true },
        { "name": "master_version", "type": "string", "description": "Master version" },
        { "name": "services_ipv4_cidr", "type": "string", "description": "Services IPv4 CIDR" },
        { "name": "instance_group_urls", "type": "list", "description": "Instance group URLs" },
        { "name": "label_fingerprint", "type": "string", "description": "Label fingerprint" },
        { "name": "node_config", "type": "list", "description": "Node config" },
        { "name": "node_pool", "type": "list", "description": "Node pools" },
        { "name": "operation", "type": "string", "description": "Operation" },
        { "name": "tpu_ipv4_cidr_block", "type": "string", "description": "TPU IPv4 CIDR" }
      ]
    },
    {
      "id": "container_node_pool",
      "name": "GKE Node Pool",
      "description": "Node pool for GKE cluster",
      "terraform_resource": "google_container_node_pool",
      "icon": "layers",
      "inputs": {
        "required": [
          { "name": "name", "type": "string", "description": "Node pool name" },
          { "name": "cluster", "type": "string", "description": "Cluster name" }
        ],
        "optional": [
          { "name": "project", "type": "string", "description": "Project ID" },
          { "name": "location", "type": "string", "description": "Location" },
          { "name": "node_count", "type": "number", "description": "Node count" },
          { "name": "initial_node_count", "type": "number", "description": "Initial node count" },
          { "name": "max_pods_per_node", "type": "number", "description": "Max pods per node" },
          { "name": "node_locations", "type": "list", "description": "Node locations" },
          { "name": "version", "type": "string", "description": "Node version" }
        ],
        "blocks": [
          {
            "name": "node_config",
            "required": false,
            "attributes": [
              { "name": "machine_type", "type": "string" },
              { "name": "disk_size_gb", "type": "number" },
              { "name": "disk_type", "type": "string" },
              { "name": "image_type", "type": "string" },
              { "name": "labels", "type": "map" },
              { "name": "local_ssd_count", "type": "number" },
              { "name": "metadata", "type": "map" },
              { "name": "min_cpu_platform", "type": "string" },
              { "name": "oauth_scopes", "type": "list" },
              { "name": "preemptible", "type": "bool" },
              { "name": "spot", "type": "bool" },
              { "name": "service_account", "type": "string" },
              { "name": "tags", "type": "list" },
              { "name": "boot_disk_kms_key", "type": "string" },
              { "name": "node_group", "type": "string" }
            ]
          },
          {
            "name": "autoscaling",
            "required": false,
            "attributes": [
              { "name": "min_node_count", "type": "number" },
              { "name": "max_node_count", "type": "number" },
              { "name": "total_min_node_count", "type": "number" },
              { "name": "total_max_node_count", "type": "number" },
              { "name": "location_policy", "type": "string", "options": ["BALANCED", "ANY"] }
            ]
          },
          {
            "name": "management",
            "required": false,
            "attributes": [
              { "name": "auto_repair", "type": "bool" },
              { "name": "auto_upgrade", "type": "bool" }
            ]
          },
          {
            "name": "upgrade_settings",
            "required": false,
            "attributes": [
              { "name": "strategy", "type": "string", "options": ["SURGE", "BLUE_GREEN"] },
              { "name": "max_surge", "type": "number" },
              { "name": "max_unavailable", "type": "number" }
            ],
            "blocks": [
              {
                "name": "blue_green_settings",
                "attributes": [
                  { "name": "node_pool_soak_duration", "type": "string" }
                ],
                "blocks": [
                  {
                    "name": "standard_rollout_policy",
                    "attributes": [
                      { "name": "batch_percentage", "type": "number" },
                      { "name": "batch_node_count", "type": "number" },
                      { "name": "batch_soak_duration", "type": "string" }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "name": "network_config",
            "required": false,
            "attributes": [
              { "name": "create_pod_range", "type": "bool" },
              { "name": "enable_private_nodes", "type": "bool" },
              { "name": "pod_ipv4_cidr_block", "type": "string" },
              { "name": "pod_range", "type": "string" }
            ],
            "blocks": [
              {
                "name": "additional_node_network_configs",
                "multiple": true,
                "attributes": [
                  { "name": "network", "type": "string" },
                  { "name": "subnetwork", "type": "string" }
                ]
              },
              {
                "name": "additional_pod_network_configs",
                "multiple": true,
                "attributes": [
                  { "name": "subnetwork", "type": "string" },
                  { "name": "secondary_pod_range", "type": "string" },
                  { "name": "max_pods_per_node", "type": "number" }
                ]
              }
            ]
          },
          {
            "name": "placement_policy",
            "required": false,
            "attributes": [
              { "name": "type", "type": "string", "required": true },
              { "name": "policy_name", "type": "string" },
              { "name": "tpu_topology", "type": "string" }
            ]
          },
          {
            "name": "queued_provisioning",
            "required": false,
            "attributes": [
              { "name": "enabled", "type": "bool", "required": true }
            ]
          }
        ]
      },
      "outputs": [
        { "name": "id", "type": "string", "description": "Node pool ID" },
        { "name": "instance_group_urls", "type": "list", "description": "Instance group URLs" },
        { "name": "managed_instance_group_urls", "type": "list", "description": "Managed instance group URLs" },
        { "name": "operation", "type": "string", "description": "Operation" }
      ]
    },
    {
      "id": "artifact_registry_repository",
      "name": "Artifact Registry",
      "description": "Artifact Registry repository",
      "terraform_resource": "google_artifact_registry_repository",
      "icon": "package",
      "inputs": {
        "required": [
          { "name": "repository_id", "type": "string", "description": "Repository ID" },
          { "name": "location", "type": "string", "description": "Location" },
