{
  "category": "messaging",
  "categoryName": "Messaging & Integration",
  "services": [
    {
      "id": "pubsub_topic",
      "name": "Pub/Sub Topic",
      "description": "Cloud Pub/Sub topic",
      "terraform_resource": "google_pubsub_topic",
      "icon": "rss",
      "inputs": {
        "required": [
          { "name": "name", "type": "string", "description": "Topic name" }
        ],
        "optional": [
          { "name": "project", "type": "string", "description": "Project ID" },
          { "name": "labels", "type": "map", "description": "Labels" },
          { "name": "kms_key_name", "type": "string", "description": "KMS key name" },
          { "name": "message_retention_duration", "type": "string", "description": "Message retention duration" }
        ],
        "blocks": [
          {
            "name": "message_storage_policy",
            "required": false,
            "attributes": [
              { "name": "allowed_persistence_regions", "type": "list", "required": true }
            ]
          },
          {
            "name": "schema_settings",
            "required": false,
            "attributes": [
              { "name": "schema", "type": "string", "required": true },
              { "name": "encoding", "type": "string", "options": ["ENCODING_UNSPECIFIED", "JSON", "BINARY"] }
            ]
          },
          {
            "name": "ingestion_data_source_settings",
            "required": false,
            "blocks": [
              {
                "name": "aws_kinesis",
                "attributes": [
                  { "name": "stream_arn", "type": "string", "required": true },
                  { "name": "consumer_arn", "type": "string", "required": true },
                  { "name": "aws_role_arn", "type": "string", "required": true },
                  { "name": "gcp_service_account", "type": "string", "required": true }
                ]
              }
            ]
          }
        ]
      },
      "outputs": [
        { "name": "id", "type": "string", "description": "Topic ID" }
      ]
    },
    {
      "id": "pubsub_subscription",
      "name": "Pub/Sub Subscription",
      "description": "Cloud Pub/Sub subscription",
      "terraform_resource": "google_pubsub_subscription",
      "icon": "bookmark",
      "inputs": {
        "required": [
          { "name": "name", "type": "string", "description": "Subscription name" },
          { "name": "topic", "type": "string", "description": "Topic name or ID" }
        ],
        "optional": [
          { "name": "project", "type": "string", "description": "Project ID" },
          { "name": "labels", "type": "map", "description": "Labels" },
          { "name": "ack_deadline_seconds", "type": "number", "description": "Ack deadline seconds", "default": 10 },
          { "name": "message_retention_duration", "type": "string", "description": "Message retention", "default": "604800s" },
          { "name": "retain_acked_messages", "type": "bool", "description": "Retain acked messages" },
          { "name": "filter", "type": "string", "description": "Filter expression" },
          { "name": "enable_message_ordering", "type": "bool", "description": "Enable message ordering" },
          { "name": "enable_exactly_once_delivery", "type": "bool", "description": "Exactly once delivery" }
        ],
        "blocks": [
          {
            "name": "expiration_policy",
            "required": false,
            "attributes": [
              { "name": "ttl", "type": "string", "required": true }
            ]
          },
          {
            "name": "dead_letter_policy",
            "required": false,
            "attributes": [
              { "name": "dead_letter_topic", "type": "string" },
              { "name": "max_delivery_attempts", "type": "number" }
            ]
          },
          {
            "name": "retry_policy",
            "required": false,
            "attributes": [
              { "name": "minimum_backoff", "type": "string" },
              { "name": "maximum_backoff", "type": "string" }
            ]
          },
          {
            "name": "push_config",
            "required": false,
            "attributes": [
              { "name": "push_endpoint", "type": "string", "required": true },
              { "name": "attributes", "type": "map" }
            ],
            "blocks": [
              {
                "name": "oidc_token",
                "attributes": [
                  { "name": "service_account_email", "type": "string", "required": true },
                  { "name": "audience", "type": "string" }
                ]
              },
              {
                "name": "no_wrapper",
                "attributes": [
                  { "name": "write_metadata", "type": "bool", "required": true }
                ]
              }
            ]
          },
          {
            "name": "bigquery_config",
            "required": false,
            "attributes": [
              { "name": "table", "type": "string", "required": true },
              { "name": "use_topic_schema", "type": "bool" },
              { "name": "use_table_schema", "type": "bool" },
              { "name": "write_metadata", "type": "bool" },
              { "name": "drop_unknown_fields", "type": "bool" }
            ]
          },
          {
            "name": "cloud_storage_config",
            "required": false,
            "attributes": [
              { "name": "bucket", "type": "string", "required": true },
              { "name": "filename_prefix", "type": "string" },
              { "name": "filename_suffix", "type": "string" },
              { "name": "filename_datetime_format", "type": "string" },
              { "name": "max_duration", "type": "string" },
              { "name": "max_bytes", "type": "number" }
            ],
            "blocks": [
              {
                "name": "avro_config",
                "attributes": [
                  { "name": "write_metadata", "type": "bool" },
                  { "name": "use_topic_schema", "type": "bool" }
                ]
              }
            ]
          }
        ]
      },
      "outputs": [
        { "name": "id", "type": "string", "description": "Subscription ID" }
      ]
    },
    {
      "id": "pubsub_schema",
      "name": "Pub/Sub Schema",
      "description": "Cloud Pub/Sub schema",
      "terraform_resource": "google_pubsub_schema",
      "icon": "file-text",
      "inputs": {
        "required": [
          { "name": "name", "type": "string", "description": "Schema name" }
        ],
        "optional": [
          { "name": "project", "type": "string", "description": "Project ID" },
          { "name": "type", "type": "string", "description": "Schema type", "options": ["TYPE_UNSPECIFIED", "PROTOCOL_BUFFER", "AVRO"] },
          { "name": "definition", "type": "string", "description": "Schema definition" }
        ]
      },
      "outputs": [
        { "name": "id", "type": "string", "description": "Schema ID" }
      ]
    },
    {
      "id": "cloud_tasks_queue",
      "name": "Cloud Tasks Queue",
      "description": "Cloud Tasks task queue",
      "terraform_resource": "google_cloud_tasks_queue",
      "icon": "list",
      "inputs": {
        "required": [
          { "name": "name", "type": "string", "description": "Queue name" },
          { "name": "location", "type": "string", "description": "Location" }
        ],
        "optional": [
          { "name": "project", "type": "string", "description": "Project ID" }
        ],
        "blocks": [
          {
            "name": "app_engine_routing_override",
            "required": false,
            "attributes": [
              { "name": "service", "type": "string" },
              { "name": "version", "type": "string" },
              { "name": "instance", "type": "string" }
            ]
          },
          {
            "name": "rate_limits",
            "required": false,
            "attributes": [
              { "name": "max_dispatches_per_second", "type": "number" },
              { "name": "max_concurrent_dispatches", "type": "number" }
            ]
          },
          {
            "name": "retry_config",
            "required": false,
            "attributes": [
              { "name": "max_attempts", "type": "number" },
              { "name": "max_retry_duration", "type": "string" },
              { "name": "min_backoff", "type": "string" },
              { "name": "max_backoff", "type": "string" },
              { "name": "max_doublings", "type": "number" }
            ]
          },
          {
            "name": "stackdriver_logging_config",
            "required": false,
            "attributes": [
              { "name": "sampling_ratio", "type": "number", "required": true }
            ]
          }
        ]
      },
      "outputs": [
        { "name": "id", "type": "string", "description": "Queue ID" }
      ]
    },
    {
      "id": "cloud_scheduler_job",
      "name": "Cloud Scheduler Job",
      "description": "Cloud Scheduler job",
      "terraform_resource": "google_cloud_scheduler_job",
      "icon": "clock",
      "inputs": {
        "required": [
          { "name": "name", "type": "string", "description": "Job name" },
          { "name": "region", "type": "string", "description": "Region" },
          { "name": "schedule", "type": "string", "description": "Cron schedule" }
        ],
        "optional": [
          { "name": "project", "type": "string", "description": "Project ID" },
          { "name": "description", "type": "string", "description": "Description" },
          { "name": "time_zone", "type": "string", "description": "Timezone", "default": "Etc/UTC" },
          { "name": "attempt_deadline", "type": "string", "description": "Attempt deadline" },
          { "name": "paused", "type": "bool", "description": "Paused" }
        ],
        "blocks": [
          {
            "name": "retry_config",
            "required": false,
            "attributes": [
              { "name": "retry_count", "type": "number" },
              { "name": "max_retry_duration", "type": "string" },
              { "name": "min_backoff_duration", "type": "string" },
              { "name": "max_backoff_duration", "type": "string" },
              { "name": "max_doublings", "type": "number" }
            ]
          },
          {
            "name": "pubsub_target",
            "required": false,
            "attributes": [
              { "name": "topic_name", "type": "string", "required": true },
              { "name": "data", "type": "string" },
              { "name": "attributes", "type": "map" }
            ]
          },
          {
            "name": "http_target",
            "required": false,
            "attributes": [
              { "name": "uri", "type": "string", "required": true },
              { "name": "http_method", "type": "string", "options": ["POST", "GET", "HEAD", "PUT", "DELETE", "PATCH", "OPTIONS"] },
              { "name": "body", "type": "string" },
              { "name": "headers", "type": "map" }
            ],
            "blocks": [
              {
                "name": "oauth_token",
                "attributes": [
                  { "name": "service_account_email", "type": "string", "required": true },
                  { "name": "scope", "type": "string" }
                ]
              },
              {
                "name": "oidc_token",
                "attributes": [
                  { "name": "service_account_email", "type": "string", "required": true },
                  { "name": "audience", "type": "string" }
                ]
              }
            ]
          },
          {
            "name": "app_engine_http_target",
            "required": false,
            "attributes": [
              { "name": "http_method", "type": "string", "options": ["POST", "GET", "HEAD", "PUT", "DELETE", "PATCH", "OPTIONS"] },
              { "name": "relative_uri", "type": "string", "required": true },
              { "name": "body", "type": "string" },
              { "name": "headers", "type": "map" }
            ],
            "blocks": [
              {
                "name": "app_engine_routing",
                "attributes": [
                  { "name": "service", "type": "string" },
                  { "name": "version", "type": "string" },
                  { "name": "instance", "type": "string" }
                ]
              }
            ]
          }
        ]
      },
      "outputs": [
        { "name": "id", "type": "string", "description": "Job ID" }
      ]
    },
    {
      "id": "workflows_workflow",
      "name": "Workflows",
      "description": "Cloud Workflows workflow",
      "terraform_resource": "google_workflows_workflow",
      "icon": "git-branch",
      "inputs": {
        "required": [
          { "name": "name", "type": "string", "description": "Workflow name" }
        ],
        "optional": [
          { "name": "project", "type": "string", "description": "Project ID" },
          { "name": "region", "type": "string", "description": "Region" },
          { "name": "description", "type": "string", "description": "Description" },
          { "name": "service_account", "type": "string", "description": "Service account" },
          { "name": "source_contents", "type": "string", "description": "Workflow YAML/JSON source" },
          { "name": "labels", "type": "map", "description": "Labels" },
          { "name": "crypto_key_name", "type": "string", "description": "KMS crypto key name" },
          { "name": "call_log_level", "type": "string", "description": "Call log level", "options": ["CALL_LOG_LEVEL_UNSPECIFIED", "LOG_ALL_CALLS", "LOG_ERRORS_ONLY", "LOG_NONE"] },
          { "name": "user_env_vars", "type": "map", "description": "User environment variables" }
        ]
      },
      "outputs": [
        { "name": "id", "type": "string", "description": "Workflow ID" },
        { "name": "name", "type": "string", "description": "Workflow name" },
        { "name": "state", "type": "string", "description": "Workflow state" },
        { "name": "revision_id", "type": "string", "description": "Revision ID" },
        { "name": "create_time", "type": "string", "description": "Create time" },
        { "name": "update_time", "type": "string", "description": "Update time" }
      ]
    },
    {
      "id": "eventarc_trigger",
      "name": "Eventarc Trigger",
      "description": "Eventarc trigger",
      "terraform_resource": "google_eventarc_trigger",
      "icon": "zap",
      "inputs": {
        "required": [
          { "name": "name", "type": "string", "description": "Trigger name" },
          { "name": "location", "type": "string", "description": "Location" }
        ],
        "optional": [
          { "name": "project", "type": "string", "description": "Project ID" },
          { "name": "service_account", "type": "string", "description": "Service account" },
          { "name": "labels", "type": "map", "description": "Labels" },
          { "name": "channel", "type": "string", "description": "Channel name" },
          { "name": "event_data_content_type", "type": "string", "description": "Content type" }
        ],
        "blocks": [
          {
            "name": "matching_criteria",
            "required": true,
            "multiple": true,
            "attributes": [
              { "name": "attribute", "type": "string", "required": true },
              { "name": "value", "type": "string", "required": true },
              { "name": "operator", "type": "string" }
            ]
          },
          {
            "name": "destination",
            "required": true,
            "attributes": [
              { "name": "cloud_run_service", "type": "string" },
              { "name": "workflow", "type": "string" }
            ],
            "blocks": [
              {
                "name": "cloud_run_service",
                "attributes": [
                  { "name": "service", "type": "string", "required": true },
                  { "name": "path", "type": "string" },
                  { "name": "region", "type": "string" }
                ]
              },
              {
                "name": "gke",
                "attributes": [
                  { "name": "cluster", "type": "string", "required": true },
                  { "name": "location", "type": "string", "required": true },
                  { "name": "namespace", "type": "string", "required": true },
                  { "name": "service", "type": "string", "required": true },
                  { "name": "path", "type": "string" }
                ]
              },
              {
                "name": "http_endpoint",
                "attributes": [
                  { "name": "uri", "type": "string", "required": true }
                ]
              },
              {
                "name": "network_config",
                "attributes": [
                  { "name": "network_attachment", "type": "string", "required": true }
                ]
              }
            ]
          },
          {
            "name": "transport",
            "required": false,
            "blocks": [
              {
                "name": "pubsub",
                "attributes": [
                  { "name": "topic", "type": "string" }
                ]
              }
            ]
          }
        ]
      },
      "outputs": [
        { "name": "id", "type": "string", "description": "Trigger ID" },
        { "name": "uid", "type": "string", "description": "Trigger UID" },
        { "name": "create_time", "type": "string", "description": "Create time" },
        { "name": "update_time", "type": "string", "description": "Update time" },
        { "name": "etag", "type": "string", "description": "Etag" }
      ]
    },
    {
      "id": "apigee_organization",
      "name": "Apigee Organization",
      "description": "Apigee API management organization",
      "terraform_resource": "google_apigee_organization",
      "icon": "box",
      "inputs": {
        "required": [
          { "name": "project_id", "type": "string", "description": "Project ID" },
          { "name": "authorized_network", "type": "string", "description": "Authorized VPC network" }
        ],
        "optional": [
          { "name": "analytics_region", "type": "string", "description": "Analytics region" },
          { "name": "api_consumer_data_location", "type": "string", "description": "API consumer data location" },
          { "name": "api_consumer_data_encryption_key_name", "type": "string", "description": "Consumer data encryption key" },
          { "name": "billing_type", "type": "string", "description": "Billing type", "options": ["EVALUATION", "SUBSCRIPTION", "PAYG"] },
          { "name": "control_plane_encryption_key_name", "type": "string", "description": "Control plane encryption key" },
          { "name": "description", "type": "string", "description": "Description" },
          { "name": "display_name", "type": "string", "description": "Display name" },
          { "name": "disable_vpc_peering", "type": "bool", "description": "Disable VPC peering" },
          { "name": "runtime_database_encryption_key_name", "type": "string", "description": "Runtime DB encryption key" },
          { "name": "runtime_type", "type": "string", "description": "Runtime type", "options": ["CLOUD", "HYBRID"] },
          { "name": "retention", "type": "string", "description": "Retention", "options": ["DELETION_RETENTION_UNSPECIFIED", "MINIMUM"] }
        ],
        "blocks": [
          {
            "name": "properties",
            "required": false,
            "blocks": [
              {
                "name": "property",
                "multiple": true,
                "attributes": [
                  { "name": "name", "type": "string" },
                  { "name": "value", "type": "string" }
                ]
              }
            ]
          }
        ]
      },
      "outputs": [
        { "name": "id", "type": "string", "description": "Organization ID" },
        { "name": "name", "type": "string", "description": "Organization name" },
        { "name": "ca_certificate", "type": "string", "description": "CA certificate" },
        { "name": "apigee_project_id", "type": "string", "description": "Apigee project ID" },
        { "name": "subscription_type", "type": "string", "description": "Subscription type" }
      ]
    }
  ]
}
