{
  "id": "staging-env",
  "name": "CloudForge Staging",
  "values": [
    {
      "key": "baseUrl",
      "value": "https://staging-api.cloudforge.example.com",
      "type": "default",
      "enabled": true
    },
    {
      "key": "testUsername",
      "value": "{{$processEnvironment STAGING_TEST_USERNAME}}",
      "type": "default",
      "enabled": true,
      "description": "Set via STAGING_TEST_USERNAME env var"
    },
    {
      "key": "testPassword",
      "value": "{{$processEnvironment STAGING_TEST_PASSWORD}}",
