      "enabled": true,
      "description": "Set via STAGING_TEST_PASSWORD env var"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "secret",
      "enabled": true
    },
    {
      "key": "tokenExpiry",
      "value": "0",
      "type": "default",
      "enabled": true
    },
    {
      "key": "responseTimeMultiplier",
      "value": "1",
      "type": "default",
      "enabled": true,
      "description": "Standard response time thresholds for staging"
    }
  ],
  "_postman_variable_scope": "environment",
  "_postman_exported_at": "2025-01-14T00:00:00.000Z",
  "_postman_exported_using": "CloudForge"
}
