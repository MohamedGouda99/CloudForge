{
  "info": {
    "name": "CloudForge API",
    "_postman_id": "cloudforge-api-collection",
    "description": "Comprehensive API test collection for CloudForge - Infrastructure as Code Platform.\n\nFeatures:\n- Automatic authentication with token caching\n- JSON schema validation for all responses\n- Response time assertions by endpoint tier\n- Multi-environment support (local, staging, production)\n\nRun with: newman run cloudforge-api.postman_collection.json -e ../environments/local.postman_environment.json",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Collection-level pre-request script for automatic authentication",
          "// This runs before EVERY request in the collection",
          "",
          "const baseUrl = pm.environment.get('baseUrl');",
          "const tokenExpiry = parseInt(pm.environment.get('tokenExpiry') || '0');",
          "const now = Date.now();",
          "",
          "// Skip auth for health endpoints and login/register",
          "const skipAuthPaths = ['/health', '/api/auth/login', '/api/auth/register'];",
          "const currentPath = pm.request.url.getPath();",
          "const shouldSkipAuth = skipAuthPaths.some(path => currentPath.includes(path));",
          "",
          "if (shouldSkipAuth) {",
          "    console.log('Skipping auth for:', currentPath);",
          "    return;",
          "}",
          "",
          "// Check if we need a new token",
          "const accessToken = pm.environment.get('accessToken');",
          "if (!accessToken || now > tokenExpiry) {",
          "    console.log('Token missing or expired, obtaining new token...');",
          "    ",
          "    const username = pm.environment.get('testUsername');",
          "    const password = pm.environment.get('testPassword');",
          "    ",
          "    if (!username || !password) {",
          "        console.error('Test credentials not configured in environment');",
          "        return;",
          "    }",
          "    ",
          "    pm.sendRequest({",
          "        url: baseUrl + '/api/auth/login',",
          "        method: 'POST',",
          "        header: {",
          "            'Content-Type': 'application/x-www-form-urlencoded'",
          "        },",
          "        body: {",
          "            mode: 'urlencoded',",
          "            urlencoded: [",
          "                { key: 'username', value: username },",
          "                { key: 'password', value: password }",
          "            ]",
          "        }",
          "    }, function(err, res) {",
          "        if (err) {",
          "            console.error('Authentication failed:', err);",
          "            return;",
          "        }",
          "        ",
          "        if (res.code === 200) {",
          "            const json = res.json();",
          "            pm.environment.set('accessToken', json.access_token);",
          "            // Token expires in 1 hour, refresh 5 minutes early",
          "            pm.environment.set('tokenExpiry', (now + 3300000).toString());",
          "            console.log('Token obtained successfully');",
          "        } else {",
          "            console.error('Login failed with status:', res.code);",
          "        }",
          "    });",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Collection-level test script - runs after EVERY request",
          "",
          "// Get response time threshold based on endpoint category",
          "function getResponseTimeThreshold() {",
          "    const path = pm.request.url.getPath();",
          "    const multiplier = parseFloat(pm.environment.get('responseTimeMultiplier') || '1');",
          "    ",
          "    // Fast tier (200ms) - Health checks",
          "    if (path.includes('/health')) {",
          "        return 200 * multiplier;",
          "    }",
          "    ",
          "    // Long-running tier (5000ms) - Security scans, cost estimation, icons catalog",
          "    if (path.includes('/tfsec') || path.includes('/terrascan') || path.includes('/infracost') || path.includes('/icons/catalog')) {",
          "        return 5000 * multiplier;",
          "    }",
          "    ",
          "    // Complex tier (2000ms) - Terraform generation",
          "    if (path.includes('/terraform/generate') || path.includes('/terraform/plan') || ",
          "        path.includes('/terraform/deploy') || path.includes('/terraform/destroy')) {",
          "        return 2000 * multiplier;",
          "    }",
          "    ",
          "    // Standard tier (500ms) - Default for CRUD operations",
          "    return 500 * multiplier;",
          "}",
          "",
          "// Response time assertion",
          "pm.test('Response time is acceptable', function() {",
          "    const threshold = getResponseTimeThreshold();",
          "    pm.expect(pm.response.responseTime).to.be.below(threshold);",
          "});",
          "",
          "// Content-Type assertion (skip for 204 No Content)",
          "if (pm.response.code !== 204) {",
          "    pm.test('Content-Type is JSON', function() {",
          "        const contentType = pm.response.headers.get('Content-Type');",
          "        if (contentType) {",
          "            pm.expect(contentType).to.include('application/json');",
          "        }",
          "    });",
          "}"
        ]
      }
    }
  ],
