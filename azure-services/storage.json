{
  "category": "storage",
  "categoryName": "Storage",
  "services": [
    {
      "id": "storage_account",
      "name": "Storage Account",
      "description": "Azure Storage Account",
      "terraform_resource": "azurerm_storage_account",
      "icon": "database",
      "inputs": {
        "required": [
          { "name": "name", "type": "string", "description": "Storage account name (3-24 lowercase chars)" },
          { "name": "resource_group_name", "type": "string", "description": "Resource group name" },
          { "name": "location", "type": "string", "description": "Azure region" },
          { "name": "account_tier", "type": "string", "description": "Account tier", "options": ["Standard", "Premium"] },
          { "name": "account_replication_type", "type": "string", "description": "Replication type", "options": ["LRS", "GRS", "RAGRS", "ZRS", "GZRS", "RAGZRS"] }
        ],
        "optional": [
          { "name": "account_kind", "type": "string", "description": "Account kind", "options": ["BlobStorage", "BlockBlobStorage", "FileStorage", "Storage", "StorageV2"], "default": "StorageV2" },
          { "name": "access_tier", "type": "string", "description": "Access tier", "options": ["Hot", "Cool"], "default": "Hot" },
          { "name": "edge_zone", "type": "string", "description": "Edge zone" },
          { "name": "enable_https_traffic_only", "type": "bool", "description": "HTTPS only", "default": true },
          { "name": "min_tls_version", "type": "string", "description": "Min TLS version", "options": ["TLS1_0", "TLS1_1", "TLS1_2"], "default": "TLS1_2" },
          { "name": "allow_nested_items_to_be_public", "type": "bool", "description": "Allow nested public items", "default": true },
          { "name": "shared_access_key_enabled", "type": "bool", "description": "Shared access key enabled", "default": true },
          { "name": "public_network_access_enabled", "type": "bool", "description": "Public network access", "default": true },
          { "name": "default_to_oauth_authentication", "type": "bool", "description": "Default to OAuth" },
          { "name": "is_hns_enabled", "type": "bool", "description": "Hierarchical namespace" },
          { "name": "nfsv3_enabled", "type": "bool", "description": "NFSv3 enabled" },
          { "name": "cross_tenant_replication_enabled", "type": "bool", "description": "Cross tenant replication", "default": true },
          { "name": "sftp_enabled", "type": "bool", "description": "SFTP enabled" },
          { "name": "large_file_share_enabled", "type": "bool", "description": "Large file share" },
          { "name": "local_user_enabled", "type": "bool", "description": "Local user enabled", "default": true },
          { "name": "queue_encryption_key_type", "type": "string", "description": "Queue encryption key type", "options": ["Account", "Service"] },
          { "name": "table_encryption_key_type", "type": "string", "description": "Table encryption key type", "options": ["Account", "Service"] },
          { "name": "infrastructure_encryption_enabled", "type": "bool", "description": "Infrastructure encryption" },
          { "name": "allowed_copy_scope", "type": "string", "description": "Allowed copy scope", "options": ["AAD", "PrivateLink"] },
          { "name": "dns_endpoint_type", "type": "string", "description": "DNS endpoint type", "options": ["Standard", "AzureDnsZone"] },
          { "name": "tags", "type": "map", "description": "Resource tags" }
        ],
        "blocks": [
          {
            "name": "identity",
            "required": false,
            "attributes": [
              { "name": "type", "type": "string", "required": true },
              { "name": "identity_ids", "type": "list" }
            ]
          },
          {
            "name": "blob_properties",
            "required": false,
            "attributes": [
              { "name": "versioning_enabled", "type": "bool" },
              { "name": "change_feed_enabled", "type": "bool" },
              { "name": "change_feed_retention_in_days", "type": "number" },
              { "name": "default_service_version", "type": "string" },
              { "name": "last_access_time_enabled", "type": "bool" }
            ],
            "blocks": [
              {
                "name": "cors_rule",
                "multiple": true,
                "attributes": [
                  { "name": "allowed_headers", "type": "list", "required": true },
                  { "name": "allowed_methods", "type": "list", "required": true },
                  { "name": "allowed_origins", "type": "list", "required": true },
                  { "name": "exposed_headers", "type": "list", "required": true },
                  { "name": "max_age_in_seconds", "type": "number", "required": true }
                ]
              },
              {
                "name": "delete_retention_policy",
                "attributes": [
                  { "name": "days", "type": "number" },
                  { "name": "permanent_delete_enabled", "type": "bool" }
                ]
              },
              {
                "name": "restore_policy",
                "attributes": [
                  { "name": "days", "type": "number", "required": true }
                ]
              },
              {
                "name": "container_delete_retention_policy",
                "attributes": [
                  { "name": "days", "type": "number" }
                ]
              }
            ]
          },
          {
            "name": "queue_properties",
            "required": false,
            "blocks": [
              {
                "name": "cors_rule",
                "multiple": true,
                "attributes": [
                  { "name": "allowed_headers", "type": "list", "required": true },
                  { "name": "allowed_methods", "type": "list", "required": true },
                  { "name": "allowed_origins", "type": "list", "required": true },
                  { "name": "exposed_headers", "type": "list", "required": true },
                  { "name": "max_age_in_seconds", "type": "number", "required": true }
                ]
              },
              {
                "name": "logging",
                "attributes": [
                  { "name": "delete", "type": "bool", "required": true },
                  { "name": "read", "type": "bool", "required": true },
                  { "name": "version", "type": "string", "required": true },
                  { "name": "write", "type": "bool", "required": true },
                  { "name": "retention_policy_days", "type": "number" }
                ]
              },
              {
                "name": "minute_metrics",
                "attributes": [
                  { "name": "enabled", "type": "bool", "required": true },
                  { "name": "version", "type": "string", "required": true },
                  { "name": "include_apis", "type": "bool" },
                  { "name": "retention_policy_days", "type": "number" }
                ]
              },
              {
                "name": "hour_metrics",
                "attributes": [
                  { "name": "enabled", "type": "bool", "required": true },
                  { "name": "version", "type": "string", "required": true },
                  { "name": "include_apis", "type": "bool" },
                  { "name": "retention_policy_days", "type": "number" }
                ]
              }
            ]
          },
          {
            "name": "share_properties",
            "required": false,
            "attributes": [
              { "name": "retention_policy", "type": "object" }
            ],
            "blocks": [
              {
                "name": "cors_rule",
                "multiple": true,
                "attributes": [
                  { "name": "allowed_headers", "type": "list", "required": true },
                  { "name": "allowed_methods", "type": "list", "required": true },
                  { "name": "allowed_origins", "type": "list", "required": true },
                  { "name": "exposed_headers", "type": "list", "required": true },
                  { "name": "max_age_in_seconds", "type": "number", "required": true }
                ]
              },
              {
                "name": "retention_policy",
                "attributes": [
                  { "name": "days", "type": "number" }
                ]
              },
              {
                "name": "smb",
                "attributes": [
                  { "name": "versions", "type": "list" },
                  { "name": "authentication_types", "type": "list" },
                  { "name": "kerberos_ticket_encryption_type", "type": "list" },
                  { "name": "channel_encryption_type", "type": "list" },
                  { "name": "multichannel_enabled", "type": "bool" }
                ]
              }
            ]
          },
          {
            "name": "static_website",
            "required": false,
            "attributes": [
              { "name": "index_document", "type": "string" },
              { "name": "error_404_document", "type": "string" }
            ]
          },
          {
            "name": "network_rules",
            "required": false,
            "attributes": [
              { "name": "default_action", "type": "string", "required": true, "options": ["Allow", "Deny"] },
              { "name": "bypass", "type": "list" },
              { "name": "ip_rules", "type": "list" },
              { "name": "virtual_network_subnet_ids", "type": "list" }
            ],
            "blocks": [
              {
                "name": "private_link_access",
                "multiple": true,
                "attributes": [
                  { "name": "endpoint_resource_id", "type": "string", "required": true },
                  { "name": "endpoint_tenant_id", "type": "string" }
                ]
              }
            ]
          },
          {
            "name": "azure_files_authentication",
            "required": false,
            "attributes": [
              { "name": "directory_type", "type": "string", "required": true, "options": ["AADDS", "AD", "AADKERB"] }
            ],
            "blocks": [
              {
                "name": "active_directory",
                "attributes": [
                  { "name": "domain_name", "type": "string", "required": true },
                  { "name": "domain_guid", "type": "string", "required": true },
                  { "name": "domain_sid", "type": "string" },
                  { "name": "storage_sid", "type": "string" },
                  { "name": "forest_name", "type": "string" },
                  { "name": "netbios_domain_name", "type": "string" }
                ]
              }
            ]
          },
          {
            "name": "routing",
            "required": false,
            "attributes": [
              { "name": "publish_internet_endpoints", "type": "bool" },
              { "name": "publish_microsoft_endpoints", "type": "bool" },
              { "name": "choice", "type": "string", "options": ["InternetRouting", "MicrosoftRouting"] }
            ]
          },
          {
            "name": "custom_domain",
            "required": false,
            "attributes": [
              { "name": "name", "type": "string", "required": true },
              { "name": "use_subdomain", "type": "bool" }
            ]
          },
          {
            "name": "customer_managed_key",
            "required": false,
            "attributes": [
              { "name": "key_vault_key_id", "type": "string" },
              { "name": "managed_hsm_key_id", "type": "string" },
              { "name": "user_assigned_identity_id", "type": "string", "required": true }
            ]
          },
          {
            "name": "immutability_policy",
            "required": false,
            "attributes": [
              { "name": "allow_protected_append_writes", "type": "bool", "required": true },
              { "name": "state", "type": "string", "required": true, "options": ["Unlocked", "Locked", "Disabled"] },
              { "name": "period_since_creation_in_days", "type": "number", "required": true }
            ]
          },
          {
            "name": "sas_policy",
            "required": false,
            "attributes": [
              { "name": "expiration_period", "type": "string", "required": true },
              { "name": "expiration_action", "type": "string", "options": ["Log"] }
            ]
          }
        ]
      },
      "outputs": [
        { "name": "id", "type": "string", "description": "Storage account ID" },
        { "name": "primary_location", "type": "string", "description": "Primary location" },
        { "name": "secondary_location", "type": "string", "description": "Secondary location" },
        { "name": "primary_blob_endpoint", "type": "string", "description": "Primary blob endpoint" },
        { "name": "primary_blob_host", "type": "string", "description": "Primary blob host" },
        { "name": "secondary_blob_endpoint", "type": "string", "description": "Secondary blob endpoint" },
        { "name": "primary_queue_endpoint", "type": "string", "description": "Primary queue endpoint" },
        { "name": "secondary_queue_endpoint", "type": "string", "description": "Secondary queue endpoint" },
        { "name": "primary_table_endpoint", "type": "string", "description": "Primary table endpoint" },
        { "name": "secondary_table_endpoint", "type": "string", "description": "Secondary table endpoint" },
        { "name": "primary_file_endpoint", "type": "string", "description": "Primary file endpoint" },
        { "name": "secondary_file_endpoint", "type": "string", "description": "Secondary file endpoint" },
        { "name": "primary_dfs_endpoint", "type": "string", "description": "Primary DFS endpoint" },
        { "name": "secondary_dfs_endpoint", "type": "string", "description": "Secondary DFS endpoint" },
        { "name": "primary_web_endpoint", "type": "string", "description": "Primary web endpoint" },
        { "name": "secondary_web_endpoint", "type": "string", "description": "Secondary web endpoint" },
        { "name": "primary_access_key", "type": "string", "description": "Primary access key", "sensitive": true },
        { "name": "secondary_access_key", "type": "string", "description": "Secondary access key", "sensitive": true },
        { "name": "primary_connection_string", "type": "string", "description": "Primary connection string", "sensitive": true },
        { "name": "secondary_connection_string", "type": "string", "description": "Secondary connection string", "sensitive": true },
        { "name": "primary_blob_connection_string", "type": "string", "description": "Primary blob connection string", "sensitive": true },
        { "name": "secondary_blob_connection_string", "type": "string", "description": "Secondary blob connection string", "sensitive": true },
        { "name": "identity", "type": "list", "description": "Managed identity" }
      ]
    },
    {
      "id": "storage_container",
      "name": "Storage Container",
      "description": "Azure Storage Blob Container",
      "terraform_resource": "azurerm_storage_container",
      "icon": "folder",
      "inputs": {
        "required": [
          { "name": "name", "type": "string", "description": "Container name" },
          { "name": "storage_account_name", "type": "string", "description": "Storage account name" }
        ],
        "optional": [
          { "name": "container_access_type", "type": "string", "description": "Access type", "options": ["blob", "container", "private"], "default": "private" },
          { "name": "default_encryption_scope", "type": "string", "description": "Default encryption scope" },
          { "name": "encryption_scope_override_enabled", "type": "bool", "description": "Override encryption scope", "default": true },
          { "name": "metadata", "type": "map", "description": "Metadata" }
        ]
      },
      "outputs": [
        { "name": "id", "type": "string", "description": "Container ID" },
        { "name": "has_immutability_policy", "type": "bool", "description": "Has immutability policy" },
        { "name": "has_legal_hold", "type": "bool", "description": "Has legal hold" },
        { "name": "resource_manager_id", "type": "string", "description": "Resource Manager ID" }
      ]
    },
    {
      "id": "storage_blob",
      "name": "Storage Blob",
      "description": "Azure Storage Blob",
      "terraform_resource": "azurerm_storage_blob",
      "icon": "file",
      "inputs": {
        "required": [
          { "name": "name", "type": "string", "description": "Blob name" },
          { "name": "storage_account_name", "type": "string", "description": "Storage account name" },
          { "name": "storage_container_name", "type": "string", "description": "Container name" },
          { "name": "type", "type": "string", "description": "Blob type", "options": ["Append", "Block", "Page"] }
        ],
        "optional": [
          { "name": "size", "type": "number", "description": "Blob size (Page blobs)" },
          { "name": "access_tier", "type": "string", "description": "Access tier", "options": ["Archive", "Cool", "Hot"] },
          { "name": "cache_control", "type": "string", "description": "Cache control" },
          { "name": "content_type", "type": "string", "description": "Content type" },
          { "name": "content_md5", "type": "string", "description": "Content MD5" },
          { "name": "encryption_scope", "type": "string", "description": "Encryption scope" },
          { "name": "source", "type": "string", "description": "Source file path" },
          { "name": "source_content", "type": "string", "description": "Source content" },
          { "name": "source_uri", "type": "string", "description": "Source URI" },
          { "name": "parallelism", "type": "number", "description": "Upload parallelism", "default": 8 },
          { "name": "metadata", "type": "map", "description": "Metadata" }
        ]
      },
      "outputs": [
        { "name": "id", "type": "string", "description": "Blob ID" },
        { "name": "url", "type": "string", "description": "Blob URL" }
      ]
    },
    {
      "id": "storage_share",
      "name": "Storage Share",
      "description": "Azure Storage File Share",
      "terraform_resource": "azurerm_storage_share",
      "icon": "share-2",
      "inputs": {
        "required": [
          { "name": "name", "type": "string", "description": "Share name" },
          { "name": "storage_account_name", "type": "string", "description": "Storage account name" },
          { "name": "quota", "type": "number", "description": "Quota in GB" }
        ],
        "optional": [
          { "name": "access_tier", "type": "string", "description": "Access tier", "options": ["Cool", "Hot", "Premium", "TransactionOptimized"] },
          { "name": "enabled_protocol", "type": "string", "description": "Enabled protocol", "options": ["NFS", "SMB"], "default": "SMB" },
          { "name": "metadata", "type": "map", "description": "Metadata" }
        ],
        "blocks": [
          {
            "name": "acl",
            "required": false,
            "multiple": true,
            "attributes": [
              { "name": "id", "type": "string", "required": true }
            ],
            "blocks": [
              {
                "name": "access_policy",
                "multiple": true,
                "attributes": [
                  { "name": "permissions", "type": "string", "required": true },
                  { "name": "start", "type": "string" },
                  { "name": "expiry", "type": "string" }
                ]
              }
            ]
          }
        ]
      },
      "outputs": [
        { "name": "id", "type": "string", "description": "Share ID" },
        { "name": "url", "type": "string", "description": "Share URL" },
        { "name": "resource_manager_id", "type": "string", "description": "Resource Manager ID" }
      ]
    },
    {
      "id": "storage_queue",
      "name": "Storage Queue",
      "description": "Azure Storage Queue",
      "terraform_resource": "azurerm_storage_queue",
      "icon": "list",
      "inputs": {
        "required": [
          { "name": "name", "type": "string", "description": "Queue name" },
          { "name": "storage_account_name", "type": "string", "description": "Storage account name" }
        ],
        "optional": [
          { "name": "metadata", "type": "map", "description": "Metadata" }
        ]
      },
      "outputs": [
        { "name": "id", "type": "string", "description": "Queue ID" },
        { "name": "resource_manager_id", "type": "string", "description": "Resource Manager ID" }
      ]
    },
    {
      "id": "storage_table",
      "name": "Storage Table",
      "description": "Azure Storage Table",
      "terraform_resource": "azurerm_storage_table",
      "icon": "grid",
      "inputs": {
        "required": [
          { "name": "name", "type": "string", "description": "Table name" },
          { "name": "storage_account_name", "type": "string", "description": "Storage account name" }
        ],
        "optional": [],
        "blocks": [
          {
            "name": "acl",
            "required": false,
            "multiple": true,
            "attributes": [
              { "name": "id", "type": "string", "required": true }
            ],
            "blocks": [
              {
                "name": "access_policy",
                "multiple": true,
                "attributes": [
                  { "name": "permissions", "type": "string", "required": true },
                  { "name": "start", "type": "string", "required": true },
                  { "name": "expiry", "type": "string", "required": true }
                ]
              }
            ]
          }
        ]
      },
      "outputs": [
        { "name": "id", "type": "string", "description": "Table ID" },
        { "name": "name", "type": "string", "description": "Table name" }
      ]
    },
    {
      "id": "storage_data_lake_gen2_filesystem",
      "name": "Data Lake Gen2 Filesystem",
      "description": "Azure Data Lake Storage Gen2 Filesystem",
      "terraform_resource": "azurerm_storage_data_lake_gen2_filesystem",
      "icon": "database",
      "inputs": {
        "required": [
          { "name": "name", "type": "string", "description": "Filesystem name" },
          { "name": "storage_account_id", "type": "string", "description": "Storage account ID" }
        ],
        "optional": [
          { "name": "properties", "type": "map", "description": "Properties" },
          { "name": "owner", "type": "string", "description": "Owner" },
          { "name": "group", "type": "string", "description": "Group" },
          { "name": "default_encryption_scope", "type": "string", "description": "Default encryption scope" }
        ],
        "blocks": [
          {
            "name": "ace",
            "required": false,
            "multiple": true,
            "attributes": [
              { "name": "scope", "type": "string" },
              { "name": "type", "type": "string", "required": true, "options": ["user", "group", "mask", "other"] },
              { "name": "id", "type": "string" },
              { "name": "permissions", "type": "string", "required": true }
            ]
          }
        ]
      },
      "outputs": [
        { "name": "id", "type": "string", "description": "Filesystem ID" }
      ]
    }
  ]
}
