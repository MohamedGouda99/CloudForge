{
  "version": "1.0",
  "metadata": {
    "name": "Serverless REST API",
    "description": "Serverless API with Lambda, API Gateway, DynamoDB, and S3",
    "cloud_provider": "aws",
    "author": "CloudForge",
    "tags": ["serverless", "lambda", "api-gateway", "dynamodb"]
  },
  "resources": [
    {
      "id": "api-gateway",
      "type": "aws_api_gateway_rest_api",
      "name": "REST API",
      "properties": {
        "description": "Main REST API Gateway",
        "endpoint_type": "REGIONAL"
      }
    },
    {
      "id": "lambda-handler",
      "type": "aws_lambda_function",
      "name": "API Handler",
      "properties": {
        "runtime": "nodejs18.x",
        "handler": "index.handler",
        "memory_size": 256,
        "timeout": 30,
        "description": "Main API request handler"
      }
    },
    {
      "id": "lambda-auth",
      "type": "aws_lambda_function",
      "name": "Authorizer",
      "properties": {
        "runtime": "nodejs18.x",
        "handler": "authorizer.handler",
        "memory_size": 128,
        "timeout": 10,
        "description": "JWT token authorizer"
      }
    },
    {
      "id": "dynamodb-users",
      "type": "aws_dynamodb_table",
      "name": "Users Table",
      "properties": {
        "billing_mode": "PAY_PER_REQUEST",
        "hash_key": "userId",
        "attribute": {
          "name": "userId",
          "type": "S"
        }
      }
    },
    {
      "id": "dynamodb-data",
      "type": "aws_dynamodb_table",
      "name": "Data Table",
      "properties": {
        "billing_mode": "PAY_PER_REQUEST",
        "hash_key": "id",
        "range_key": "timestamp",
        "attribute": [
          { "name": "id", "type": "S" },
          { "name": "timestamp", "type": "N" }
        ]
      }
    },
    {
      "id": "s3-uploads",
      "type": "aws_s3_bucket",
      "name": "Uploads Bucket",
      "properties": {
        "bucket_prefix": "app-uploads-"
      }
    },
    {
      "id": "s3-static",
      "type": "aws_s3_bucket",
      "name": "Static Assets",
      "properties": {
        "bucket_prefix": "app-static-"
      }
    },
    {
      "id": "cloudfront",
      "type": "aws_cloudfront_distribution",
      "name": "CDN",
      "properties": {
        "enabled": true,
        "default_root_object": "index.html"
      }
    },
    {
      "id": "cognito-pool",
      "type": "aws_cognito_user_pool",
      "name": "User Pool",
      "properties": {
        "name": "app-users",
        "auto_verified_attributes": ["email"]
      }
    }
  ],
  "connections": [
    {
      "from": "api-gateway",
      "to": "lambda-handler"
    },
    {
      "from": "api-gateway",
      "to": "lambda-auth"
    },
    {
      "from": "lambda-handler",
      "to": "dynamodb-users"
    },
    {
      "from": "lambda-handler",
      "to": "dynamodb-data"
    },
    {
      "from": "lambda-handler",
      "to": "s3-uploads"
    },
    {
      "from": "cloudfront",
      "to": "s3-static"
    },
    {
      "from": "lambda-auth",
      "to": "cognito-pool"
    }
  ]
}
